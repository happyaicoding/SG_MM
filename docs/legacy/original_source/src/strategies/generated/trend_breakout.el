// AISMART Strategy: Trend_Breakout
// Auto-generated by AISMART StrategyGenerator (do not edit manually)
// Python source: trend_breakout.py

[IntrabarOrderGeneration = false]
// Category: trend  Direction: both
// Timeframe: 60min

inputs:
    EMAPeriod(50),       { EMA period for trend direction }
    BreakoutWindow(20),  { lookback window for recent high/low }
    ATRMultiplier(2.0),  { ATR multiplier for stop loss }
    CloseBefore(30);     { force close N bars before end }

variables:
    TrendEMA(0),
    WindowHigh(0),
    WindowLow(0),
    ATRValue(0),
    InLong(false),
    InShort(false),
    LongStop(0),
    ShortStop(0),
    CurrentBar(0),
    LastBar(0);

TrendEMA    = XAverage(Close, EMAPeriod);
WindowHigh  = Highest(High, BreakoutWindow);
WindowLow   = Lowest(Low, BreakoutWindow);
ATRValue    = AvgTrueRange(14);

CurrentBar  = CurrentBar + 1;
LastBar     = BarCount - CloseBefore;

if Close > TrendEMA and Close > WindowHigh and not InLong and not InShort then
    Buy("LE") next bar at market;

if Close < TrendEMA and Close < WindowLow and not InShort and not InLong then
    Sell Short("SE") next bar at market;

LongStop  = TrendEMA - ATRMultiplier * ATRValue;
ShortStop = TrendEMA + ATRMultiplier * ATRValue;

if InLong and Close < LongStop then
    ExitLong("LX-ATR") next bar at market;

if InShort and Close > ShortStop then
    ExitShort("SX-ATR") next bar at market;

if MarketPosition = 1 then
    InLong = true
else
    InLong = false;

if MarketPosition = -1 then
    InShort = true
else
    InShort = false;

if LastBar > 0 and CurrentBar >= LastBar then begin
    if MarketPosition = 1 then
        ExitLong("LX-FC") next bar at market;
    if MarketPosition = -1 then
        ExitShort("SX-FC") next bar at market;
end;