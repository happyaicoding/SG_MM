# === 執行環境 ===
ENVIRONMENT=development           # development | production
TIMEZONE=Asia/Taipei

# === LLM API（成本優先：NIM → Minimax → Claude）===
NIM_API_KEY=your_nim_api_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === 資料路徑 ===
DATA_PATH=./data
SQLITE_PATH=./data/sqlite/main.db
DUCKDB_PATH=./data/duckdb/strategy_vectors.duckdb
HF_HOME=./data/models           # bge-m3 模型快取（首次下載約 2.3GB）

# === MC Bridge（Windows Native，MultiCharts COM 自動化）===
MC_BRIDGE_HOST=127.0.0.1
MC_BRIDGE_PORT=8001
MC_DIR=C:/Program Files/TS Support/MultiCharts64
MC_STUDIES_DIR=C:/ProgramData/TS Support/MultiCharts64/StudyServer/Studies/SrcEl/Strategies

# === 預算控制（每日上限，超過硬停）===
DAILY_BUDGET_USD=10.0
HARD_STOP_USD=10.0

# === Web 服務 ===
API_PORT=8000
WEBUI_PORT=3000

# === Cloudflare Tunnel（Phase 4 後，空值 = 停用）===
CF_TUNNEL_TOKEN=
